rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == userId
          && data.email is string && data.email.size() < 256
          && (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() < 128))
          && (data.get('categories', null) == null || data.categories is list)
          && (data.get('settings', null) == null || data.settings is map);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().userId == existing().userId;
    }

    // Task Rules
    match /tasks/{taskId} {
      function isValidTask(data) {
        return (data.get('title', '') is string)
          && (data.get('userId', '') is string)
          && (data.get('completed', false) is bool)
          && (data.get('createdAt', request.time) is timestamp)
          && (data.get('updatedAt', request.time) is timestamp);
      }

      function isTaskOwner() {
        return isSignedIn() && (
          (resource == null && incoming().userId == request.auth.uid) ||
          (resource != null && existing().userId == request.auth.uid)
        );
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isTaskOwner() 
        && isValidTask(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isTaskOwner()
        && isValidTask(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isTaskOwner();
    }
  }
}
